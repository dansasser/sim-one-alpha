# Model choice lives in the shipped gorombo.config.json runtime config.
# Keep only secrets and service connection values in .env.
OPENAI_API_KEY=
API_SECRET=local_testing_secret

# Direct Ollama Cloud API. Uses https://ollama.com/v1 by default.
OLLAMA_API_KEY=
OLLAMA_CLOUD_API_KEY=

# Default RAG web search provider. Uses the existing Ollama API key.
GOROMBO_WEB_SEARCH_PROVIDER=ollama
OLLAMA_WEB_SEARCH_BASE_URL=https://ollama.com
OLLAMA_WEB_SEARCH_TIMEOUT_MS=8000
GOROMBO_RAG_MAX_CONTEXT_TOKENS=4000
GOROMBO_RAG_WEB_FETCH_TOP_K=1
GOROMBO_RESEARCH_MAX_QUERIES=3
GOROMBO_RESEARCH_MAX_FETCHES=2
GOROMBO_RESEARCH_MAX_CONTEXT_TOKENS=4000
GOROMBO_RESEARCH_CACHE=sqlite
GOROMBO_RESEARCH_CACHE_DB=.gorombo/research-cache.sqlite

# Optional local Ollama endpoint for actual Ollama local models.
OLLAMA_CLOUD_BASE_URL=https://ollama.com/v1
OLLAMA_LOCAL_BASE_URL=http://localhost:11434/v1
OLLAMA_LOCAL_API_KEY=

# Optional Codex Brain endpoint. This is not Ollama Local.
# Use the OpenAI-compatible base URL including /v1.
CODEX_BRAIN_LOCAL_API_URL=
CODEX_BRAIN_LOCAL_API_KEY=

# Optional alternate search providers for later RAG provider expansion.
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
