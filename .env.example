# Optional exact model override. Prefer GOROMBO_MODEL_PROFILE for project-owned model choices.
GOROMBO_MODEL=
GOROMBO_MODEL_PROFILE=minimax-m3-cloud
OPENAI_API_KEY=
API_SECRET=local_testing_secret

# Direct Ollama Cloud API. Uses https://ollama.com/v1 by default.
OLLAMA_API_KEY=

# Optional local or DT1 Ollama-compatible endpoint for local profiles.
OLLAMA_CLOUD_BASE_URL=https://ollama.com/v1
OLLAMA_LOCAL_BASE_URL=http://localhost:11434/v1
OLLAMA_LOCAL_API_KEY=
OLLAMA_CODEX_BRAIN_MODEL=

# Optional web search provider for the next RAG implementation step.
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
