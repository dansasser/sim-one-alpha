GOROMBO_MODEL=openai/gpt-5.5
OPENAI_API_KEY=
API_SECRET=local_testing_secret

# Ollama local or cloud-compatible testing.
# If OLLAMA_API_KEY or OLLAMA_BASE_URL is set and GOROMBO_MODEL is not,
# the agent defaults to ollama/minimax-m3:cloud.
OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=minimax-m3:cloud

# Optional web search provider for the next RAG implementation step.
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
