{
  "name": "sim-one-alpha",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SIM-ONE Alpha — Flue-based multi-purpose orchestrating agent foundation.",
  "files": [
    "dist/**",
    "scripts/test-built-http.mjs",
    "scripts/smoke-http-endpoints.mjs",
    "README.md",
    ".env.example"
  ],
  "scripts": {
    "build": "flue build --target node && node scripts/copy-runtime-config.mjs && node scripts/copy-wasm-artifact.mjs",
    "connect": "flue connect orchestrator local --target node --session local",
    "dev": "flue dev --target node",
    "test:unit": "node scripts/run-unit-tests.mjs",
    "test:http": "node scripts/test-built-http.mjs",
    "test:lsp": "node scripts/run-unit-tests.mjs -- src/tests/lsp-integration.test.ts",
    "smoke:http": "node scripts/smoke-http-endpoints.mjs",
    "research:local": "node scripts/research.mjs",
    "protocols:seed": "node scripts/protocol-admin.mjs seed",
    "protocols:list": "node scripts/protocol-admin.mjs list",
    "protocols:add": "node scripts/protocol-admin.mjs add",
    "protocols:remove": "node scripts/protocol-admin.mjs remove",
    "protocols:enable": "node scripts/protocol-admin.mjs enable",
    "protocols:disable": "node scripts/protocol-admin.mjs disable",
    "capabilities:list": "node scripts/capability-admin.mjs list",
    "capabilities:add": "node scripts/capability-admin.mjs add",
    "capabilities:enable": "node scripts/capability-admin.mjs enable",
    "capabilities:disable": "node scripts/capability-admin.mjs disable",
    "capabilities:remove": "node scripts/capability-admin.mjs remove",
    "capabilities:update": "node scripts/capability-admin.mjs update",
    "start": "node --env-file=.env dist/server.mjs",
    "build:prod": "node scripts/build-prod.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run test:unit && pnpm run build && pnpm run test:http",
    "fetch-embedding-model": "node scripts/fetch-embedding-model.mjs",
    "wasm:build": "node scripts/wasm-build.mjs",
    "prebuild": "node scripts/wasm-build.mjs",
    "smoke:memory": "node scripts/smoke-memory-helper.mjs",
    "cargo:test": "cargo test -p gorombo-memory"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "dependencies": {
    "@ai-sdk/provider": "^3.0.10",
    "@astrojs/language-server": "^2.16.10",
    "@flue/runtime": "1.0.0-beta.1",
    "@flue/telegram": "1.0.0-beta.1",
    "@huggingface/tokenizers": "^0.1.3",
    "@lancedb/lancedb": "^0.30.0",
    "@runpod/ai-sdk-provider": "^1.4.0",
    "ai": "^6.0.205",
    "croner": "^10.0.1",
    "grammy": "^1.44.0",
    "hono": "^4.12.23",
    "js-yaml": "^4.2.0",
    "onnxruntime-node": "^1.26.0",
    "proper-lockfile": "^4.1.2",
    "pyright": "^1.1.410",
    "typescript": "^6.0.3",
    "typescript-language-server": "^5.3.0",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@flue/cli": "1.0.0-beta.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.2",
    "@types/proper-lockfile": "^4.1.4"
  },
  "packageManager": "pnpm@10.10.0"
}
